# Auto detect text files and perform LF normalization
* text=auto

# Dart files should use LF line endings
*.dart text eol=lf

# YAML files should use LF line endings
*.yaml text eol=lf
*.yml text eol=lf

# Python files should use LF line endings
*.py text eol=lf

# Shell scripts should use LF line endings
*.sh text eol=lf

# Windows scripts should use CRLF line endings
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.pyc binary
*.pdf binary
